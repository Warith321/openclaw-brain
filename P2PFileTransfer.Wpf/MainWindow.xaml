<Window x:Class="P2PFileTransfer.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="P2P File Transfer (WPF)" Height="560" Width="900">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="基于 Socket 的 P2P 文件传输" FontSize="20" FontWeight="Bold"/>

        <Grid Grid.Row="1" Margin="0,12,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <GroupBox Header="接收端" Margin="0,0,8,0">
                <StackPanel Margin="10">
                    <TextBlock Text="监听端口"/>
                    <TextBox x:Name="ReceivePortBox" Text="9000" Margin="0,4,0,8"/>

                    <TextBlock Text="保存目录"/>
                    <DockPanel Margin="0,4,0,8">
                        <TextBox x:Name="SaveDirBox" Text="./recv" Margin="0,0,8,0"/>
                        <Button Content="浏览" Width="70" Click="BrowseSaveDir_Click"/>
                    </DockPanel>

                    <Button Content="启动接收" Height="34" Click="StartReceive_Click"/>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="发送端" Grid.Column="1" Margin="8,0,0,0">
                <StackPanel Margin="10">
                    <TextBlock Text="目标 IP"/>
                    <TextBox x:Name="HostBox" Text="127.0.0.1" Margin="0,4,0,8"/>

                    <TextBlock Text="目标端口"/>
                    <TextBox x:Name="SendPortBox" Text="9000" Margin="0,4,0,8"/>

                    <TextBlock Text="文件路径"/>
                    <DockPanel Margin="0,4,0,8">
                        <TextBox x:Name="FilePathBox" Margin="0,0,8,0"/>
                        <Button Content="选择" Width="70" Click="PickFile_Click"/>
                    </DockPanel>

                    <Button Content="发送文件" Height="34" Click="SendFile_Click"/>
                </StackPanel>
            </GroupBox>
        </Grid>

        <GroupBox Grid.Row="2" Header="日志 / 进度">
            <DockPanel Margin="10">
                <ProgressBar x:Name="Progress" Height="22" DockPanel.Dock="Top" Minimum="0" Maximum="100" Margin="0,0,0,8"/>
                <TextBox x:Name="LogBox" IsReadOnly="True" VerticalScrollBarVisibility="Auto" TextWrapping="Wrap" AcceptsReturn="True"/>
            </DockPanel>
        </GroupBox>
    </Grid>
</Window>
